# ── Copy to `.env` for local dev, OR set these as env vars in Cloud Run ──
# (Never commit the real .env — it holds secrets.)

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials)
google_client_id=YOUR_CLIENT_ID.apps.googleusercontent.com
google_client_secret=YOUR_CLIENT_SECRET

# Where Google sends the user back after login.
#  - Local:      http://localhost:8000/auth/callback
#  - Production:  https://YOUR-SERVICE-URL/auth/callback   (must match the
#                 Authorized redirect URI you add in the OAuth client)
google_redirect_uri=http://localhost:8000/auth/callback

# Master secret — signs sessions AND derives the AES-256 key for stored tokens.
# MUST be strong & STABLE. Generate once:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
secret_key=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Database.
#  - Local:      sqlite:///./admob_tool.db
#  - Production:  postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require
database_url=sqlite:///./admob_tool.db

# Production hardening (set these on Cloud Run):
#   cookie_secure=true   → session cookie only over HTTPS
#   debug=false          → refuse to start with a weak secret_key
cookie_secure=false
debug=true
